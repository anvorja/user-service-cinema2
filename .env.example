# Database (shared Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/cinema_db

# JWT — must match auth-service exactly
JWT_SECRET=your-secret-here
JWT_ALGORITHM=HS256

# Redis (Upstash) — for blacklist checks
REDIS_URL=redis://:password@host:6379

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:8090","http://localhost:5173"]

DEBUG=false
